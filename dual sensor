#include <Wire.h>
#include <VL53L1X.h>

VL53L1X s1;
VL53L1X s2;

const uint8_t SDA_PIN = 21;
const uint8_t SCL_PIN = 22;

const uint8_t XSHUT_1 = 32;   
const uint8_t XSHUT_2 = 33;   

// Pick two new addresses (must be different and not 0x29)
const uint8_t ADDR_1 = 0x30;
const uint8_t ADDR_2 = 0x31;

bool initSensor(VL53L1X &sensor, uint8_t xshutPin, uint8_t newAddr) {
  digitalWrite(xshutPin, HIGH);   // power up this sensor
  delay(50);

  sensor.setTimeout(500);

  if (!sensor.init()) return false;

  sensor.setAddress(newAddr);                 // change from 0x29 -> newAddr
  sensor.setDistanceMode(VL53L1X::Long);
  sensor.setMeasurementTimingBudget(50000);   // 50 ms
  sensor.startContinuous(50);                 // 50 ms period

  return true;
}

void setup() {
  Serial.begin(115200);
  delay(200);

  Wire.begin(SDA_PIN, SCL_PIN);
  Wire.setClock(400000);

  pinMode(XSHUT_1, OUTPUT);
  pinMode(XSHUT_2, OUTPUT);

  // Hold both sensors in reset/off first
  digitalWrite(XSHUT_1, LOW);
  digitalWrite(XSHUT_2, LOW);
  delay(20);

  // Bring up sensor 1, assign address 0x30
  if (!initSensor(s1, XSHUT_1, ADDR_1)) {
    Serial.println("ERROR: Sensor 1 init failed");
    while (1) delay(1000);
  }
  Serial.println("Sensor 1 OK @ 0x30");

  // Bring up sensor 2, assign address 0x31
  if (!initSensor(s2, XSHUT_2, ADDR_2)) {
    Serial.println("ERROR: Sensor 2 init failed");
    while (1) delay(1000);
  }
  Serial.println("Sensor 2 OK @ 0x31");
}

void loop() {
  uint16_t d1 = s1.read();
  uint16_t d2 = s2.read();

  if (s1.timeoutOccurred() || s2.timeoutOccurred()) {
    Serial.println("TIMEOUT");
  } else {
    Serial.print("S1: "); Serial.print(d1); Serial.print(" mm");
    Serial.print("   ");
    Serial.print("S2: "); Serial.print(d2); Serial.println(" mm");
  }

  delay(100);
}
