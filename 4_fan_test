// ESP32 (Arduino core 3.x) - 4x independent 4-wire PWM fan control
// Pins: GPIO25, GPIO26, GPIO17, GPIO16
// PWM: 25 kHz, 8-bit duty (0..255)
// Assumes NPN pull-down on each fan PWM wire => inverted logic

const int FAN1_PIN = 25;
const int FAN2_PIN = 26;
const int FAN3_PIN = 17;
const int FAN4_PIN = 16;

const int PWM_FREQ = 25000;
const int PWM_RES  = 8;

const bool INVERTED_BY_NPN = true;

uint32_t dutyMax;

void setFanPercent(int pin, int percent) {
  if (percent < 0) percent = 0;
  if (percent > 100) percent = 100;

  uint32_t duty = (uint32_t)(percent * dutyMax / 100);

  if (INVERTED_BY_NPN) {
    duty = dutyMax - duty;
  }

  ledcWrite(pin, duty);
}

void setAllFansPercent(int percent) {
  setFanPercent(FAN1_PIN, percent);
  setFanPercent(FAN2_PIN, percent);
  setFanPercent(FAN3_PIN, percent);
  setFanPercent(FAN4_PIN, percent);
}

void rampAllFans() {
  Serial.println("Ramping all fans up...");

  for (int percent = 0; percent <= 100; percent++) {
    setAllFansPercent(percent);

    // Print less often to reduce Serial Monitor load
    if (percent % 10 == 0) {
      Serial.print("All fans: ");
      Serial.print(percent);
      Serial.println("%");
    }

    delay(50);
  }

  Serial.println("Ramping all fans down...");

  for (int percent = 100; percent >= 0; percent--) {
    setAllFansPercent(percent);

    if (percent % 10 == 0) {
      Serial.print("All fans: ");
      Serial.print(percent);
      Serial.println("%");
    }

    delay(50);
  }

  Serial.println("Ramp complete.");
}

int fanNumberToPin(int fanNumber) {
  if (fanNumber == 1) return FAN1_PIN;
  if (fanNumber == 2) return FAN2_PIN;
  if (fanNumber == 3) return FAN3_PIN;
  if (fanNumber == 4) return FAN4_PIN;
  return -1;
}

void setup() {
  Serial.begin(115200);
  delay(200);

  // Shorter timeout helps avoid long blocking on serial parsing
  Serial.setTimeout(50);

  dutyMax = (1UL << PWM_RES) - 1;

  if (!ledcAttach(FAN1_PIN, PWM_FREQ, PWM_RES)) {
    Serial.println("ERROR: ledcAttach failed for FAN1_PIN (25)");
    while (true) delay(1000);
  }

  if (!ledcAttach(FAN2_PIN, PWM_FREQ, PWM_RES)) {
    Serial.println("ERROR: ledcAttach failed for FAN2_PIN (26)");
    while (true) delay(1000);
  }

  if (!ledcAttach(FAN3_PIN, PWM_FREQ, PWM_RES)) {
    Serial.println("ERROR: ledcAttach failed for FAN3_PIN (17)");
    while (true) delay(1000);
  }

  if (!ledcAttach(FAN4_PIN, PWM_FREQ, PWM_RES)) {
    Serial.println("ERROR: ledcAttach failed for FAN4_PIN (16)");
    while (true) delay(1000);
  }

  setFanPercent(FAN1_PIN, 0);
  setFanPercent(FAN2_PIN, 0);
  setFanPercent(FAN3_PIN, 0);
  setFanPercent(FAN4_PIN, 0);

  Serial.println("Ready");
  Serial.println("Commands:");
  Serial.println("  1 50   -> set fan 1 to 50%");
  Serial.println("  2 80   -> set fan 2 to 80%");
  Serial.println("  3 25   -> set fan 3 to 25%");
  Serial.println("  4 100  -> set fan 4 to 100%");
  Serial.println("  5      -> ramp all fans");
}

void loop() {
  if (!Serial.available()) {
    delay(5);   // small pause so loop is not spinning at full speed
    return;
  }

  String line = Serial.readStringUntil('\n');
  line.trim();

  if (line.length() == 0) return;

  int a = -1;
  int b = 0;

  // Special case: just "5" for ramp
  if (line == "5") {
    rampAllFans();
    return;
  }

  // Try to parse "fan percent"
  int spaceIndex = line.indexOf(' ');
  if (spaceIndex < 0) {
    Serial.println("Bad command. Use: fan percent   or   5");
    return;
  }

  String firstPart = line.substring(0, spaceIndex);
  String secondPart = line.substring(spaceIndex + 1);
  secondPart.trim();

  a = firstPart.toInt();
  b = secondPart.toInt();

  int targetPin = fanNumberToPin(a);

  if (targetPin == -1) {
    Serial.println("Bad command: enter 1, 2, 3, 4 for a fan, or 5 to ramp all four");
    return;
  }

  if (b < 0 || b > 100) {
    Serial.println("Bad percent: enter a value from 0 to 100");
    return;
  }

  setFanPercent(targetPin, b);

  Serial.print("Set fan on GPIO ");
  Serial.print(targetPin);
  Serial.print(" to ");
  Serial.print(b);
  Serial.println("%");
}
