// ESP32 (Arduino core 3.x) - 2x independent 4-wire PWM fan control
// Pins: GPIO25 and GPIO26
// PWM: 25 kHz, 8-bit duty (0..255)
// Assumes NPN pull-down on each fan PWM wire => inverted logic


const int FAN1_PIN = 25;
const int FAN2_PIN = 26;

const int PWM_FREQ = 25000;
const int PWM_RES  = 8;

const bool INVERTED_BY_NPN = true;

//Initialize dutymax variable to toggle pwm resolution
uint32_t dutyMax;

// Function to write the pwm duty cycle given a percentage input 0 to 100
void setFanPercent(int pin, int percent) {
  if (percent < 0) percent = 0;
  if (percent > 100) percent = 100;

  uint32_t duty = (uint32_t)(percent * dutyMax / 100);

  if (INVERTED_BY_NPN) duty = dutyMax - duty;

  ledcWrite(pin, duty);
}

void setup() {
  Serial.begin(115200);
  delay(200);

  // Duty max is defined by pwm resolution
  // When pwm setFanPercent function is called then dutymax determines what the pwm value will be
  dutyMax = (1UL << PWM_RES) - 1;

  // Attach PWM generators to both pins
  if (!ledcAttach(FAN1_PIN, PWM_FREQ, PWM_RES)) {
    Serial.println("ERROR: ledcAttach failed for FAN1_PIN (25)");
    while (true) delay(1000);
  }
  if (!ledcAttach(FAN2_PIN, PWM_FREQ, PWM_RES)) {
    Serial.println("ERROR: ledcAttach failed for FAN2_PIN (26)");
    while (true) delay(1000);
  }

  // Start both fans at 0% with the percetnage duty cycle function
  setFanPercent(FAN1_PIN, 0);
  setFanPercent(FAN2_PIN, 0);
}

void loop() {
  // Wait for input into the serial monitor
  if (!Serial.available()) return;

  // fan number (1/2)
  int a = Serial.parseInt();  

  // percent 0..100
  int b = Serial.parseInt();  
  
  // clear buffer
  while (Serial.available()) Serial.read(); 

  // Set pin checker value for invalid entries
  int targetPin = -1;

  // Enter in 1 or 2 for fans 1 or 2
  if (a == 1) targetPin = FAN1_PIN;
  else if (a == 2) targetPin = FAN2_PIN;

  if (targetPin == -1) {
    Serial.println("Bad command: enter in 1 or 2 for fan address");
    return;
  }

  // Call the fan percent function to write pwm values
  setFanPercent(targetPin, b);

  Serial.print("Set fan on GPIO");
  Serial.print(targetPin);
  Serial.print(" to ");
  Serial.print(b);
  Serial.println("%");
}
